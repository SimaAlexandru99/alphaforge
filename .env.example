# Database — PostgreSQL (Prisma Postgres, Neon, or local `docker compose up`)
# Example (replace with your connection string):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DATABASE_URL=""
# Vercel + Prisma Postgres integration may expose one of these — the app and
# `pnpm run vercel:env` map them to DATABASE_URL automatically:
# STORAGE_PRISMA_DATABASE_URL=""
# STORAGE_POSTGRES_URL=""

# Vercel Cron: set the same value in Project → Settings → Environment Variables.
# Invocations of `/api/cron/agent-tick` must send `Authorization: Bearer <CRON_SECRET>`.
# Leave unset locally to skip auth during `next dev`; if set, curl must use the same value
# (Next loads .env — your shell does not: `export CRON_SECRET=...` or `-H "Bearer <paste>"`).
# Production: run `pnpm run vercel:env` to push all vars + generate CRON_SECRET if missing.
CRON_SECRET=""

# Trading mode: "paper" (safe, no real money) or "live"
TRADING_MODE="paper"

# Kraken API (get from https://www.kraken.com/u/security/api)
KRAKEN_API_KEY=""
KRAKEN_API_SECRET=""

# Kraken CLI path (install: cargo install kraken-cli)
KRAKEN_CLI_PATH="/home/user/.cargo/bin/kraken"

# Set to "true" to skip actual CLI calls and simulate locally
KRAKEN_CLI_SIMULATE="false"

# PRISM API (market signals — get from https://prism.app)
PRISM_API_KEY=""

# LLM (OpenAI — get from https://platform.openai.com/api-keys)
LLM_PROVIDER="openai"
LLM_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""

# ERC-8004 on-chain identity (Sepolia testnet)
# Generate a wallet: cast wallet new  (or use MetaMask)
AGENT_PRIVATE_KEY=""
AGENT_WALLET_ADDRESS=""

# Set after running: pnpm exec tsx scripts/register-agent.ts
ERC8004_AGENT_ID=""

# Sepolia RPC (get from https://alchemy.com or https://infura.io)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"

# Legacy (no longer used — kept for reference)
BASE_SEPOLIA_RPC="https://sepolia.base.org"
