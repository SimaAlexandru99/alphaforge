// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum DecisionAction {
  BUY
  SELL
  HOLD
}

enum RunStatus {
  OBSERVED
  EXECUTED
  BLOCKED
  FAILED
}

enum TradeStatus {
  OPEN
  CLOSED
}

model AgentConfig {
  id              String   @id @default("default")
  isEnabled       Boolean  @default(false)
  /// Set by Vercel Cron (`/api/cron/agent-tick`); survives across requests on the same DB file.
  lastCronHeartbeat DateTime?
  tradingMode     String   @default("paper")
  symbolsJson     String   @default("[\"BTCUSD\",\"ETHUSD\"]")
  loopIntervalSec Int      @default(60)
  maxExposurePct  Float    @default(0.10)
  stopLossPct     Float    @default(0.03)
  takeProfitPct   Float    @default(0.05)
  maxDrawdownPct  Float    @default(0.15)
  defaultOrderUsd Float    @default(100)
  llmProvider     String?  @default("heuristic")
  llmModel        String?  @default("gpt-4o-mini")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SignalSnapshot {
  id          String   @id @default(cuid())
  symbol      String
  price       Float
  rsi         Float?
  trend       String?
  volatility  Float?
  riskScore   Float?
  payloadJson String?
  createdAt   DateTime @default(now())

  @@index([symbol, createdAt(sort: Desc)])
}

model AgentRun {
  id            String         @id @default(cuid())
  symbol        String
  action        DecisionAction
  status        RunStatus
  reason        String
  blockedReason String?
  price         Float
  quantity      Float?
  orderValueUsd Float?
  executionMode String?
  riskScore     Float?
  metadataJson  String?
  createdAt     DateTime       @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([symbol, createdAt(sort: Desc)])
}

model Trade {
  id             String      @id @default(cuid())
  symbol         String
  status         TradeStatus @default(OPEN)
  quantity       Float
  entryPrice     Float
  currentPrice   Float?
  exitPrice      Float?
  realizedPnl    Float?
  decisionReason String?
  orderRef       String?
  executionMode  String
  openedAt       DateTime    @default(now())
  closedAt       DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([status, symbol])
  @@index([openedAt(sort: Desc)])
}
